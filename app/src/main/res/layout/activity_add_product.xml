<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="32dp"
    android:background="@color/background_light">

    <TextView
        android:id="@+id/tv_add_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nuevo Producto"
        android:textColor="@color/primary_green"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_add_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Completa los datos del item"
        android:textColor="@color/gray_text"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_add_title" />

    <EditText
        android:id="@+id/et_product_name"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/edit_text_background"
        android:hint="Nombre del producto"
        android:paddingHorizontal="20dp"
        android:inputType="textCapSentences"
        app:layout_constraintTop_toBottomOf="@id/tv_add_subtitle" />

    <EditText
        android:id="@+id/et_product_category"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/edit_text_background"
        android:hint="Categoría (ej: Electrónica)"
        android:paddingHorizontal="20dp"
        android:inputType="textCapWords"
        app:layout_constraintTop_toBottomOf="@id/et_product_name" />

    <LinearLayout
        android:id="@+id/ll_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/et_product_category">

        <EditText
            android:id="@+id/et_product_stock"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:background="@drawable/edit_text_background"
            android:hint="Stock inicial"
            android:inputType="number"
            android:paddingHorizontal="20dp" />

        <EditText
            android:id="@+id/et_product_price"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:background="@drawable/edit_text_background"
            android:hint="Precio ($)"
            android:inputType="numberDecimal"
            android:paddingHorizontal="20dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_save_product"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="48dp"
        android:background="@drawable/button_rounded"
        android:text="Registrar Producto"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@null"
        app:layout_constraintTop_toBottomOf="@id/ll_row" />

    <TextView
        android:id="@+id/tv_cancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Cancelar"
        android:textColor="@color/gray_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_save_product" />

</androidx.constraintlayout.widget.ConstraintLayout>
